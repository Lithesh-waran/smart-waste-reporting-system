# Copy to .env for local development (optional; python-dotenv loads it automatically).

# Required when FLASK_ENV=production (Dockerfile sets this).
SECRET_KEY=replace-with-a-long-random-string

# development | production
FLASK_ENV=development

# 1 = Flask debug toolbar-style errors (never use in production)
FLASK_DEBUG=0

# HTTP port for `python app.py` (Gunicorn in Docker uses PORT from the platform)
PORT=5000

# SQLite file path (default: waste.db next to app.py). Use a persistent volume path in Docker/K8s.
# DATABASE_PATH=/data/waste.db

# Set when behind nginx/Traefik/Cloudflare so sessions and redirects use HTTPS (requires TLS at the edge)
# SESSION_COOKIE_SECURE=1

# Set when the app sits behind a reverse proxy (X-Forwarded-* headers)
# BEHIND_PROXY=1

# --- Vercel (Project → Settings → Environment Variables) ---
# Production: FLASK_ENV=production and SECRET_KEY are required or the app crashes on startup.
# FLASK_ENV=production
# SECRET_KEY=<long random string>
# VERCEL_* are injected automatically. SQLite and uploads use /tmp and reset on cold starts;
# for durable data use an external DB and blob storage.
